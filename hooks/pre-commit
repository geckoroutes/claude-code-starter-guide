#!/usr/bin/env bash
# Pre-commit hook: block commits containing sensitive personal info.
# This repo is a public starter guide — no real IPs, keys, or personal details.
#
# Setup: git config core.hooksPath hooks

set -e

RED='\033[0;31m'
NC='\033[0m'

# Patterns to block — prevents committing secrets and personal info.
# Add your own patterns below (one regex per line).
PATTERNS=(
    # ── Your infrastructure (add your own) ──────────────────────────
    # '123\.456\.789\.0'            # your server IP
    # 'yourdomain\.com'             # your domain
    # 'youruser@'                   # your SSH username

    # ── SSH / private keys ──────────────────────────────────────────
    'BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY'
    'htpasswd'

    # ── API keys and tokens ─────────────────────────────────────────
    'ghp_[A-Za-z0-9]{36}'          # GitHub PAT
    'sk-[A-Za-z0-9]{48}'           # OpenAI API key
    'sk-ant-[A-Za-z0-9-]+'         # Anthropic API key
    'xoxb-[A-Za-z0-9-]+'           # Slack bot token
    'AKIA[0-9A-Z]{16}'             # AWS access key
    'password\s*[:=]\s*["\x27].+'  # hardcoded passwords
)

FOUND=0

for pattern in "${PATTERNS[@]}"; do
    # Check staged diff for the pattern (ignore this hook file itself)
    if git diff --cached --diff-filter=d -- . ':!hooks/pre-commit' | grep -qiE "$pattern"; then
        echo -e "${RED}BLOCKED:${NC} Staged changes contain sensitive pattern: ${pattern}"
        git diff --cached --name-only --diff-filter=d -- . ':!hooks/pre-commit' | while read -r file; do
            git diff --cached -- "$file" | grep -qiE "$pattern" && echo "  → $file"
        done
        FOUND=1
    fi
done

if [ "$FOUND" -eq 1 ]; then
    echo ""
    echo "Remove the sensitive info before committing."
    echo "To bypass (emergency only): git commit --no-verify"
    exit 1
fi

exit 0
